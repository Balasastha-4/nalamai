# PostgreSQL Configuration
# Local dev: use the "postgres" superuser from the installer (no extra role). Docker Compose still uses "nalamai" via env.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# PgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_admin_password_here
PGADMIN_PORT=5050

# Backend Server Configuration
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Database Connection (JDBC format for Spring Boot)
DATABASE_URL=jdbc:postgresql://localhost:5432/postgres

# Database Connection Pool
DB_POOL_SIZE=10
DB_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000

# JPA/Hibernate Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=your-secret-key-change-this-in-production-should-be-at-least-256-bits-long-for-security
JWT_EXPIRATION=86400000

# Security Configuration
SECURITY_USER=admin
SECURITY_PASSWORD=admin

# Logging Levels
LOG_SQL=DEBUG
LOG_SQL_PARAMS=TRACE
APP_LOG_LEVEL=DEBUG
